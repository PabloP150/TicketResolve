# Terraform
.terraform/
*.tfstate
*.tfstate.*
crash.log
crash.*.log

# Archives generated by `data "archive_file"` at plan time.
infra/modules/compute/build/

# Bootstrap workspace state is intentionally committed (see infra/bootstrap/README and PDF pitfall section).
# Re-include it explicitly.
!infra/bootstrap/terraform.tfstate
!infra/bootstrap/terraform.tfstate.backup

# Personal/working directories at repo root — not part of the deliverable.
# Leading slash anchors to the repo root so infra/docs/ (an official deliverable)
# is NOT caught by this rule.
/cloud/
/docs/
/optimizacion/
/testing/

# Sensitive variable files — never commit. Use dev.tfvars / prod.tfvars for non-sensitive overrides.
*.secret.tfvars
*.private.tfvars
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# OS
.DS_Store
Thumbs.db
