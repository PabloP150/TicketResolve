            "id": "451198371",
            "json": "{\n  \"Version\": \"2012-10-17\",\n  \"Statement\": [\n    {\n      \"Sid\": \"ProvisionProjectResources\",\n      \"Effect\": \"Allow\",\n      \"Action\": [\n        \"sqs:*\",\n        \"sns:*\",\n        \"secretsmanager:*\",\n        \"scheduler:*\",\n        \"s3:*\",\n        \"route53:*\",\n        \"logs:*\",\n        \"lambda:*\",\n        \"kms:*\",\n        \"iam:*\",\n        \"ec2:Describe*\",\n        \"dynamodb:*\",\n        \"cloudwatch:*\",\n        \"cloudfront:*\",\n        \"budgets:*\",\n        \"apigateway:*\",\n        \"acm:*\"\n      ],\n      \"Resource\": \"*\"\n    }\n  ]\n}",
            "minified_json": "{\"Version\":\"2012-10-17\",\"Statement\":[{\"Sid\":\"ProvisionProjectResources\",\"Effect\":\"Allow\",\"Action\":[\"sqs:*\",\"sns:*\",\"secretsmanager:*\",\"scheduler:*\",\"s3:*\",\"route53:*\",\"logs:*\",\"lambda:*\",\"kms:*\",\"iam:*\",\"ec2:Describe*\",\"dynamodb:*\",\"cloudwatch:*\",\"cloudfront:*\",\"budgets:*\",\"apigateway:*\",\"acm:*\"],\"Resource\":\"*\"}]}",
            "override_json": null,
